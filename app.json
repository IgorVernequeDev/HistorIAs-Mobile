{
  "expo": {
    "name": "HistorIAs",
    "slug": "HistorIAs",
    "icon": "./assets/img/icon.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "HistorIAs",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.HistorIAs",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-font",
      "expo-audio",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "c358bee0-9e49-4325-98be-39406080358b"
      }
    }
  }
}
